# quant-hedge-ai — Variables d'environnement (exemple)
# Copier ce fichier en .env et adapter les valeurs
# NE PAS committer le fichier .env (il est dans .gitignore)

# ── Boucle principale ───────────────────────────────────────
V9_MAX_CYCLES=0           # 0 = boucle infinie, N = N cycles puis arrêt
V9_POPULATION_SIZE=300    # Nombre de stratégies dans la population
V9_SLEEP_SECONDS=60       # Pause entre deux cycles (secondes)

# ── Marché (CCXT — données publiques, pas de clé API requise) ─
V9_CCXT_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT
V9_CCXT_TIMEFRAME=1h
V9_CCXT_HISTORY_LIMIT=200
V9_CCXT_EXCHANGES=binance,kraken,okx
V9_CCXT_CACHE_TTL=60

# ── Alertes Telegram (optionnel) ────────────────────────────
# Laisser vide pour désactiver les notifications
V9_TELEGRAM_BOT_TOKEN=
V9_TELEGRAM_CHAT_ID=

# ── Risque ─────────────────────────────────────────────────
V9_CB_DAILY_LOSS_LIMIT=0.05
V9_CB_DRAWDOWN_LIMIT=0.15
V9_CB_CONSECUTIVE_LOSSES=5
V9_SL_PCT=0.05
V9_TP_PCT=0.10
V9_SL_TRAILING_ENABLED=false

# ── Walk-Forward ────────────────────────────────────────────
V9_WFO_ENABLED=false
V9_WFO_N_SPLITS=5

# ── Rapport HTML ────────────────────────────────────────────
V9_REPORT_ENABLED=false
V9_REPORT_FREQUENCY=10    # Générer un rapport tous les N cycles
